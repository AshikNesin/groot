{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(git pull *)",
      "Bash(rtk proxy *)",
      "Bash(pnpm prisma *)",
      "Bash(pnpm db:migrate:reset)",
      "Bash(pnpm exec *)",
      "Bash(PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=yes pnpm exec varlock run -- prisma migrate reset --force)",
      "Bash(docker exec groot-local-dev-db *)"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false
  }
}
