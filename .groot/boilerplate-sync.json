{
  "boilerplate": {
    "name": "groot",
    "repo": "https://github.com/AshikNesin/groot"
  },
  "sync_config": {
    "exclude_patterns": [
      "README.md",
      "pnpm-lock.yaml",
      ".env",
      ".env.local",
      ".env.development",
      ".env.production",
      "prisma/schema.prisma",
      "prisma/migrations/**",
      "dist/**",
      "node_modules/**"
    ],
    "merge_strategy": {
      "package.json": "merge_deps",
      ".gitignore": "append_missing"
    }
  },
  "sync_history": []
}
