# Port the server will listen on. Defaults to 3000 if not specified.
PORT=3000

# Database (auto-set during local dev via `pnpm dev`, only needed for production)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=30d

# Admin Auth Key (for admin-only endpoints)
ADMIN_AUTH_KEY=your-admin-auth-key-change-in-production

# Logging
LOG_LEVEL=info

# WebAuthn / Passkey Configuration
# RP_NAME: Relying Party name shown to users during passkey registration
RP_NAME=Express React Boilerplate
# RP_ID: Your domain (use "localhost" for development)
RP_ID=localhost
# ORIGIN: Full URL of your frontend (must match exactly)
ORIGIN=http://localhost:3000

# Sentry DSN for error tracking
SENTRY_DSN=https://public@sentry.example.com/1

# CORS (optional)
# CORS_ALLOWED_ORIGINS=http://example.com,http://another.example.com

# Storage configuration
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack
AWS_DEFAULT_REGION=us-east-1
AWS_DEFAULT_S3_BUCKET=local-bucket

# Pushover Notifications (for server startup alerts)
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_api_token

# Local Database Mode (for development)
# - unset: Auto-detect (Docker if available, else PGlite)
# - pglite: Force PGlite mode (zero-config, single connection limit)
# - docker: Force Docker mode (multi-connection, requires Docker running)
# LOCAL_DB_MODE=

# Docker PostgreSQL port (default: 5433 to avoid conflicts with local Postgres)
# LOCAL_DB_DOCKER_PORT=5433

# Job Queue (PgBoss)
# - Docker mode: Enabled by default (multi-connection support)
# - PGlite mode: Disabled by default (single connection limit)
# Override the default behavior by setting this explicitly:
# ENABLE_JOB_QUEUE=true

# Local Development Seed User
# Email: test@test.com
# Password: password
# (Auto-created on first run, safe to change after)
