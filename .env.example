# Port the server will listen on. Defaults to 3000 if not specified.
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d

# Admin Auth Key (for admin-only endpoints)
ADMIN_AUTH_KEY=your-admin-auth-key-change-in-production

# Logging
LOG_LEVEL=info

# WebAuthn / Passkey Configuration
# RP_NAME: Relying Party name shown to users during passkey registration
RP_NAME=Express React Boilerplate
# RP_ID: Your domain (use "localhost" for development)
RP_ID=localhost
# ORIGIN: Full URL of your frontend (must match exactly)
ORIGIN=http://localhost:3000

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn_here

# CORS (optional)
# CORS_ALLOWED_ORIGINS=http://example.com,http://another.example.com

# Storage configuration
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack
AWS_DEFAULT_REGION=us-east-1
AWS_DEFAULT_S3_BUCKET=local-bucket
