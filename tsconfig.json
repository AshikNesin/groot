{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@groot/ui/*": ["./packages/ui/src/*"],
      "@groot/shell/*": ["./packages/shell/src/*"],
      "@groot/core/*": ["./packages/core/src/*"],
      "@groot/jobs/server": ["./packages/jobs/src/server/index.ts"],
      "@groot/jobs/server/*": ["./packages/jobs/src/server/*"],
      "@groot/jobs/client": ["./packages/jobs/src/client/index.ts"],
      "@groot/jobs/client/*": ["./packages/jobs/src/client/*"]
    }
  },
  "include": [
    "apps/web/src/server/**/*",
    "packages/core/src/**/*",
    "packages/jobs/src/server/**/*",
    "env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
