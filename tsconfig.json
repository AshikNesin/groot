{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./server/src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["server/src/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "verbatimModuleSyntax": true
  },
  "include": ["server/src/**/*", "server/src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
