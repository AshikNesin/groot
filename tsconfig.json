{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "@groot/ui/*": ["./packages/ui/src/*"],
      "@groot/client/*": ["./packages/client/src/core/*"],
      "@groot/client/index.css": ["./packages/client/src/index.css"],
      "@groot/server/core/*": ["./packages/server/src/core/*"],
      "@groot/server/shared/*": ["./packages/server/src/shared/*"],
      "@groot/database": ["./packages/database/src/index.ts"],
      "@groot/database/client": ["./packages/database/src/client.ts"],
      "@groot/database/types": ["./packages/database/src/types.ts"]
    }
  },
  "include": [
    "apps/web/src/server/**/*",
    "packages/server/src/**/*",
    "packages/database/src/**/*",
    "env.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
