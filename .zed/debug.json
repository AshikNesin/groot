[
  {
    "adapter": "JavaScript",
    "label": "Debug Current TS File (Node)",
    "type": "node",
    "request": "launch",
    "program": "$ZED_FILE",
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/run-with-varlock.sh",
    "runtimeArgs": ["node", "--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "console": "integratedTerminal",
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug Dev Server",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/scripts/dev.ts",
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/run-with-varlock.sh",
    "runtimeArgs": ["node", "--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "env": {
      "NODE_ENV": "development"
    },
    "console": "integratedTerminal",
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug Server Only",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/server/src/index.ts",
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/run-with-varlock.sh",
    "runtimeArgs": ["node", "--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "env": {
      "NODE_ENV": "development"
    },
    "console": "integratedTerminal",
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug Vitest Current File",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/node_modules/vitest/vitest.mjs",
    "args": ["run", "$ZED_FILE"],
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/run-with-varlock.sh",
    "runtimeArgs": ["node"],
    "console": "integratedTerminal",
    "cwd": "$ZED_WORKTREE_ROOT",
    "autoAttachChildProcesses": true,
    "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug Vitest All Tests",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/node_modules/vitest/vitest.mjs",
    "args": ["run"],
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/run-with-varlock.sh",
    "runtimeArgs": ["node"],
    "console": "integratedTerminal",
    "cwd": "$ZED_WORKTREE_ROOT",
    "autoAttachChildProcesses": true,
    "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Attach to Node Process",
    "type": "node",
    "request": "attach",
    "port": 9229,
    "skipFiles": ["<node_internals>/**"]
  }
]
