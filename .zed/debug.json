[
  {
    "adapter": "JavaScript",
    "label": "Debug Server (with Portless)",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/server/src/index.ts",
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/debug-server.sh",
    "runtimeArgs": ["--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "env": {
      "NODE_ENV": "development"
    },
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug Server (no Portless)",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/server/src/index.ts",
    "runtimeExecutable": "$ZED_WORKTREE_ROOT/.zed/debug-server.sh",
    "runtimeArgs": ["--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "env": {
      "NODE_ENV": "development",
      "PORTLESS": "0"
    },
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Attach to Node Process",
    "type": "node",
    "request": "attach",
    "port": 9229,
    "cwd": "$ZED_WORKTREE_ROOT",
    "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
  }
]
