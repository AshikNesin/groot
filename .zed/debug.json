[
  {
    "adapter": "JavaScript",
    "label": "Debug Server",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/server/src/index.ts",
    "runtimeArgs": ["--import", "$ZED_WORKTREE_ROOT/node_modules/tsx/dist/loader.mjs"],
    "env": {
      "NODE_ENV": "development"
    },
    "skipFiles": ["<node_internals>/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Attach to Node Process",
    "type": "node",
    "request": "attach",
    "port": 9229,
    "skipFiles": ["<node_internals>/**"]
  }
]
