# This env file uses @env-spec - see https://varlock.dev/env-spec for more info

# @currentEnv=$NODE_ENV
# @defaultRequired=infer @defaultSensitive=true
# @generateTypes(lang=ts, path=env.d.ts)
#
# Secrets management: Doppler is OPTIONAL. Precedence for each secret below is:
#   1. Ambient env var (e.g. set directly by Coolify/docker/k8s) always wins.
#   2. Otherwise the schema resolver runs: in dev it uses the inline fallback
#      (zero-config); in production it fetches via doppler().
# So you can run production two ways:
#   - Without Doppler: set each secret directly via your hosting platform.
#   - With Doppler:    set only DOPPLER_TOKEN and leave the secrets unset;
#                      varlock fetches them from the config named $NODE_ENV.
# @plugin(@varlock/doppler-plugin)
# @initDoppler(project=groot, config=$NODE_ENV, serviceToken=$DOPPLER_TOKEN)
# ----------


# @type=enum(development, production, test)
# @required @public
NODE_ENV=development

# Database engine. "sqlite" (default) uses a local file via better-sqlite3;
# "postgres" uses a PostgreSQL server via @prisma/adapter-pg. The choice
# selects the Prisma schema, driver adapter, KV store, and connection string
# format (see packages/core/src/database/engine.ts).
# @type=enum(sqlite, postgres) @public
DATABASE_ENGINE=sqlite

# Doppler service token. Optional — only needed if you fetch secrets via Doppler.
# Placeholder is never sent to Doppler because the resolvers only run when the
# matching secret is not already set in the environment. In production set the
# real token via your hosting platform's env var management (e.g. Coolify).
# @type=dopplerServiceToken @sensitive @internal
DOPPLER_TOKEN=local-dev-placeholder

# Database connection.
# - sqlite (default): a file path, e.g. file:./data/dev.db ("file:" prefix optional),
#   or ":memory:". A relative path is resolved against the project root.
#   Defaults to ./data/dev.db in development and ./tmp/test.db in test.
# - postgres: a PostgreSQL URL, e.g. postgresql://user:pass@host:port/db.
#   Postgres has no built-in default — run your own Postgres and set DATABASE_URL
#   explicitly (there is no Docker container management in this repo).
# @type=string
# @required=forEnv(production)
DATABASE_URL=if(eq($DATABASE_ENGINE, postgres), "", if(forEnv(development), "file:./data/dev.db", if(forEnv(test), "file:./tmp/test.db")))

# Test database URL (test env only). Branches on DATABASE_ENGINE like above.
# @type=string
# @required=forEnv(test)
TEST_DATABASE_URL=if(eq($DATABASE_ENGINE, postgres), "", if(forEnv(test), "file:./tmp/test.db"))

# Direct (session-mode) PostgreSQL URL for Prisma migrate/introspection.
# Only relevant for pooled Postgres (e.g. Supabase Supavisor / PgBouncer);
# ignored for sqlite. Optional in dev; required in production when
# DATABASE_URL is pooled.
# @type=string
DATABASE_URL_DIRECT=

# JWT Authentication
# @required
# @type=string(minLength=32)
JWT_SECRET_KEY=if(forEnv(production), doppler(), "your-super-secret-jwt-key-min-32-characters-long")

# Admin Auth Key (for admin-only endpoints)
# @required
ADMIN_AUTH_KEY=if(forEnv(production), doppler(), "your-admin-auth-key-change-in-production")

# Server port (set automatically by hosting platforms like Coolify)
# @type=number @public
PORT=3000

# Storage configuration
#
# In production the S3 adapter is used (see server/src/core/storage). In dev/test
# the filesystem adapter is used instead, writing objects under ./local/uploads
# with a sidecar .meta.json per file. The AWS_* values are still required in dev
# for anything that reads the bucket name directly (e.g. public-file shares).
# @required @public
AWS_ACCESS_KEY_ID=if(forEnv(production), doppler(), "localstack")
# @required
AWS_SECRET_ACCESS_KEY=if(forEnv(production), doppler(), "localstack")
# @required @public
AWS_REGION=us-east-1
# @required @public
AWS_DEFAULT_S3_BUCKET=local-bucket

# Sentry DSN for error tracking
# @type=url @public
SENTRY_DSN=
# Sentry Release (used by instrument.ts + build scripts)
# @public
SENTRY_RELEASE=
# Source commit SHA (set by Coolify with "Include Source Commit in Build" enabled)
# @type=string @public
SOURCE_COMMIT=
# Sentry organization slug (build-time only, used by vite.config.ts and scripts/build.mjs)
# @type=string @public
SENTRY_ORG=
# Sentry auth token for source map upload (build-time only)
# @type=string
SENTRY_AUTH_TOKEN=


# AI Provider API Key
# An API key is required for AI features.
# Not wired to Doppler by default — doppler() errors if a secret is missing
# from your config. To fetch from Doppler in production, change the line to:
#   OPENAI_API_KEY=if(forEnv(production), doppler(), "")
# and make sure the key exists in your Doppler config.
OPENAI_API_KEY=


# Groot Resolve (boilerplate-sync conflict resolver)
# `pnpm groot:resolve` shells out to the pi coding agent CLI (https://pi.dev,
# `npm install -g --ignore-scripts @earendil-works/pi-coding-agent`).
# Authentication is pi's: use any provider API key pi supports (e.g.
# ZAI_API_KEY for the ZAI Coding Plan) or `pi` + /login. The optional knobs
# below pin a provider/model instead of pi's configured default. These are
# dev-tooling values (never reach the production server bundle) and are not
# Doppler-wired by default.
# @sensitive
ZAI_API_KEY=
# @public
GROOT_RESOLVE_PROVIDER=
# @public
GROOT_RESOLVE_MODEL=


# Coolify
# @type=number @public
NIXPACKS_NODE_VERSION=22

# @public
CORS_ALLOWED_ORIGINS=

# Push Notifications
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
