# This env file uses @env-spec - see https://varlock.dev/env-spec for more info

# @currentEnv=$NODE_ENV
# @defaultRequired=infer @defaultSensitive=true
# @generateTypes(lang=ts, path=env.d.ts)
# ----------


# @type=enum(development, production, test)
# @required @public
NODE_ENV=development

# Port the server will listen on. Defaults to 3000 if not specified.
# @type=number @public
PORT=3000

# Portless proxy port (8888 avoids needing sudo on macOS/Linux)
# @type=number @public
PORTLESS_PORT=8888

# Database (auto-set during local dev via `pnpm dev`, only needed for production)
# @type=url
# @required=forEnv(production)
DATABASE_URL=

# JWT Authentication
# @required
# @type=string(minLength=32)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# @required @public
JWT_EXPIRES_IN=30d

# Admin Auth Key (for admin-only endpoints)
# @required
ADMIN_AUTH_KEY=your-admin-auth-key-change-in-production

# Logging
# @type=enum(debug, info, warn, error) @public
LOG_LEVEL=info

# WebAuthn / Passkey Configuration
# RP_NAME: Relying Party name shown to users during passkey registration
# @public
RP_NAME=Groot
# RP_ID: Your domain (use "localhost" for development)
# @public
RP_ID=localhost
# ORIGIN: Full URL of your frontend (must match exactly)
# @type=url @public
ORIGIN=https://groot.localhost

# Storage configuration
# @required @public
AWS_ACCESS_KEY_ID=localstack
# @required
AWS_SECRET_ACCESS_KEY=localstack
# @required @public
AWS_REGION=us-east-1
# @required @public
AWS_DEFAULT_S3_BUCKET=local-bucket

# Sentry DSN for error tracking
# @type=url
SENTRY_DSN=
# @public
SENTRY_RELEASE=

# Background Jobs Configuration
# @type=number @public
JOB_CONCURRENCY=5
# @type=number @public
JOB_POLL_INTERVAL=5
# @type=number @public
JOB_ARCHIVE_COMPLETED_AFTER_SECONDS=604800
# @type=number @public
JOB_DELETE_ARCHIVED_AFTER_SECONDS=2592000
# @type=number @public
JOB_MONITOR_STATE_INTERVAL=60
# @type=boolean @public
ENABLE_JOB_QUEUE=true

# Docker PostgreSQL port (default: 5433 to avoid conflicts with local Postgres)
# @public
LOCAL_DB_DOCKER_PORT=5433

# AI Provider API Keys
# At least one provider API key is required for AI features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# AI Configuration
# @public
AI_DEFAULT_PROVIDER=anthropic
# @public
AI_DEFAULT_MODEL=claude-sonnet-4-6
# @type=boolean @public
AI_ENABLE_STREAMING=true
# @type=boolean @public
AI_TRACK_USAGE=true

# Coolify
# @type=number @public
NIXPACKS_NODE_VERSION=22

# @public
CORS_ALLOWED_ORIGINS=
