{
  "name": "groot",
  "version": "1.0.0",
  "description": "A minimal boilerplate for building Express.js and React.js applications",
  "keywords": [],
  "homepage": "https://github.com/AshikNesin/groot#readme",
  "bugs": {
    "url": "https://github.com/AshikNesin/groot/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshikNesin/groot.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development PORTLESS_PORT=8888 portless run --name $npm_package_name varlock run -- tsx scripts/dev.ts",
    "dev:debug": "NODE_ENV=development PORTLESS_PORT=8888 portless run --name $npm_package_name varlock run -- node --inspect --import ./node_modules/tsx/dist/loader.mjs server/src/index.ts",
    "docker:db": "varlock run -- tsx scripts/docker-db-cleanup.ts",
    "build": "varlock run -- sh -c 'rm -rf dist && prisma generate && vp build && node scripts/build.mjs'",
    "start": "NODE_ENV=production varlock run -- node dist/bundle.js",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "test": "varlock run -- vp test run",
    "test:watch": "varlock run -- vp test",
    "test:e2e": "PORTLESS=0 varlock run -- playwright test",
    "test:e2e:ui": "varlock run -- playwright test --ui",
    "prisma:push": "varlock run -- prisma db push",
    "prisma:generate": "varlock run -- prisma generate",
    "generate": "varlock run -- prisma generate",
    "db:migrate": "varlock run -- prisma migrate deploy",
    "db:migrate:create": "varlock run -- prisma migrate dev --create-only",
    "db:migrate:reset": "varlock run -- prisma migrate reset",
    "db:seed": "varlock run -- prisma db seed",
    "prestart": "varlock run -- prisma migrate deploy",
    "postinstall": "node scripts/varlock.js -- prisma generate",
    "prepare": "vp config",
    "groot:check": "tsx .groot/sync.ts check",
    "groot:sync": "tsx .groot/sync.ts apply"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/view": "^6.40.0",
    "@hookform/resolvers": "^3.10.0",
    "@keyv/postgres": "^2.2.3",
    "@mariozechner/pi-ai": "^0.58.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/node": "^9.47.1",
    "@sentry/profiling-node": "^9.47.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@uiw/react-codemirror": "^4.25.8",
    "@varlock/infisical-plugin": "^0.0.4",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "close-with-grace": "^2.5.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "console-feed": "^3.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "lucide-react": "^0.552.0",
    "multer": "^2.1.1",
    "nuqs": "^2.8.9",
    "p-limit": "^7.3.0",
    "pg-boss": "^12.14.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "send-push-notification": "^2.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "varlock": "^0.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@prisma/client": "^7.7.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.8",
    "esbuild": "^0.27.4",
    "esbuild-plugin-alias": "^0.2.1",
    "jsdom": "^26.1.0",
    "micromatch": "^4.0.8",
    "postcss": "^8.5.8",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
