{
  "name": "groot",
  "version": "1.10.0",
  "description": "A minimal boilerplate for building Express.js and React.js applications",
  "keywords": [],
  "homepage": "https://github.com/AshikNesin/groot#readme",
  "bugs": {
    "url": "https://github.com/AshikNesin/groot/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshikNesin/groot.git"
  },
  "type": "module",
  "main": "dist/bundle.js",
  "scripts": {
    "dev": "NODE_ENV=development PORTLESS_PORT=8888 portless run --name $npm_package_name varlock run -- tsx scripts/dev.ts",
    "dev:debug": "NODE_ENV=development PORTLESS_PORT=8888 portless run --name $npm_package_name varlock run -- node --inspect --import ./node_modules/tsx/dist/loader.mjs server/src/index.ts",
    "docker:db": "varlock run -- tsx scripts/docker-db-cleanup.ts",
    "build": "varlock run -- sh -c 'rm -rf dist && prisma generate && vp build && node scripts/build.mjs'",
    "start": "NODE_ENV=production varlock run -- node dist/bundle.js",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "check:tokens": "tsx scripts/check-design-tokens.ts",
    "test": "varlock run -- vp test run --config vitest.config.server.ts",
    "test:watch": "varlock run -- vp test --config vitest.config.server.ts",
    "test:e2e": "PORTLESS=0 varlock run -- playwright test",
    "test:e2e:ui": "varlock run -- playwright test --ui",
    "prisma:generate": "varlock run -- prisma generate",
    "generate": "varlock run -- prisma generate",
    "db:migrate": "varlock run -- prisma migrate deploy",
    "db:migrate:create": "varlock run -- prisma migrate dev --create-only",
    "db:migrate:reset": "varlock run -- prisma migrate reset",
    "db:baseline": "varlock run -- node scripts/db-sync-baseline.cjs",
    "db:seed": "varlock run -- prisma db seed",
    "prestart": "varlock run -- prisma migrate deploy",
    "postinstall": "node scripts/varlock.js -- prisma generate",
    "prepare": "vp config",
    "groot:setup": "bash .groot/setup-boilerplate.sh",
    "groot:check": "tsx .groot/sync.ts check",
    "groot:sync": "tsx .groot/sync.ts apply",
    "groot:resolve": "tsx .groot/resolve.ts",
    "groot:upstream": "tsx .groot/upstream.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-presigned-post": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "6.12.4",
    "@codemirror/lint": "6.9.7",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.4",
    "@earendil-works/pi-ai": "^0.80.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@keyv/postgres": "^2.2.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "@sentry/node": "^10.63.0",
    "@sentry/profiling-node": "^10.63.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@uiw/react-codemirror": "^4.25.10",
    "@varlock/doppler-plugin": "^2.0.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "close-with-grace": "^2.5.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "compression": "^1.8.1",
    "console-feed": "^3.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "files-sdk": "^2.0.0",
    "js-yaml": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "lodash.mergewith": "^4.6.2",
    "lucide-react": "^1.23.0",
    "ms": "2.1.3",
    "multer": "^2.2.0",
    "nuqs": "^2.9.0",
    "openai": "^6.45.0",
    "p-limit": "^7.3.0",
    "pg-boss": "^12.25.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "send-push-notification": "^2.2.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "varlock": "^1.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@prisma/client": "^7.8.0",
    "@sentry/esbuild-plugin": "^5.3.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash.merge": "^4.6.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "baseline-browser-mapping": "^2.10.41",
    "esbuild": "^0.28.1",
    "esbuild-plugin-alias": "^0.2.1",
    "jsdom": "^29.1.1",
    "micromatch": "^4.0.8",
    "postcss": "^8.5.16",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1"
}
