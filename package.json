{
  "name": "express-react-boilerplate",
  "version": "1.0.0",
  "description": "A minimal boilerplate for building Express.js and React.js applications",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "NODE_ENV=development tsx watch server/src/index.ts",
    "build": "vite build && node scripts/build.mjs",
    "start": "NODE_ENV=production node dist/bundle.js",
    "lint": "biome lint .",
    "format": "biome format --write server/src client/src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "generate": "prisma generate",
    "postinstall": "pnpm run prisma:generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshikNesin/express-react-boilerplate.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AshikNesin/express-react-boilerplate/issues"
  },
  "homepage": "https://github.com/AshikNesin/express-react-boilerplate#readme",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.5",
    "esbuild-plugin-alias": "^0.2.1",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.2.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.5",
    "@keyv/postgres": "^2.1.7",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.0.7",
    "@radix-ui/react-label": "^2.0.3",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-slot": "^1.0.5",
    "@sentry/node": "^9.24.0",
    "@sentry/profiling-node": "^9.24.0",
    "@t3-oss/env-core": "^0.13.6",
    "@tanstack/react-query": "^5.90.7",
    "axios": "^1.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "keyv": "^5.5.3",
    "lucide-react": "^0.552.0",
    "nuqs": "^2.7.3",
    "pg-boss": "^12.2.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.42",
    "zustand": "^5.0.8"
  }
}
