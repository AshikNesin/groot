{
  "name": "groot",
  "version": "1.0.0",
  "description": "A minimal boilerplate for building Express.js and React.js applications",
  "keywords": [],
  "homepage": "https://github.com/AshikNesin/groot#readme",
  "bugs": {
    "url": "https://github.com/AshikNesin/groot/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshikNesin/groot.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "prebuild": "rm -rf dist",
    "dev": "NODE_ENV=development tsx scripts/dev.ts",
    "dev:pglite": "LOCAL_DB_MODE=pglite NODE_ENV=development tsx scripts/dev.ts",
    "dev:docker": "LOCAL_DB_MODE=docker NODE_ENV=development tsx scripts/dev.ts",
    "dev:server": "NODE_ENV=development tsx watch server/src/index.ts",
    "dev:db:stop": "prisma dev stop",
    "dev:db:docker:stop": "tsx scripts/docker-db-cleanup.ts --stop",
    "dev:db:docker:reset": "tsx scripts/docker-db-cleanup.ts --reset",
    "dev:db:docker:status": "tsx scripts/docker-db-cleanup.ts --status",
    "dev:studio": "test -f .dev-db-url && DATABASE_URL=$(cat .dev-db-url) prisma studio || echo '❌ Start the dev server first: pnpm dev'",
    "build": "vp build && node scripts/build.mjs",
    "start": "NODE_ENV=production node dist/bundle.js",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "generate": "prisma generate",
    "postinstall": "pnpm run prisma:generate",
    "prepare": "vp config"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@aws-sdk/s3-request-presigner": "^3.922.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/view": "^6.39.12",
    "@hookform/resolvers": "^3.9.5",
    "@keyv/postgres": "^2.1.7",
    "@mariozechner/pi-ai": "^0.58.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.7",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-slot": "^1.0.5",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@sentry/node": "^9.24.0",
    "@sentry/profiling-node": "^9.24.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.2",
    "@t3-oss/env-core": "^0.13.6",
    "@tanstack/react-query": "^5.90.7",
    "@uiw/react-codemirror": "^4.25.4",
    "axios": "^1.13.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "console-feed": "^3.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "keyv": "^5.5.3",
    "lucide-react": "^0.552.0",
    "multer": "^2.0.0",
    "nuqs": "^2.7.3",
    "pg-boss": "^12.2.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.4.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-router-dom": "^7.9.5",
    "send-push-notification": "^2.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.42",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@prisma/dev": "^0.20.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.15.29",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.7",
    "esbuild": "^0.27.4",
    "esbuild-plugin-alias": "^0.2.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.26.0"
}
