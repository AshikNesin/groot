// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider            = "prisma-client"
  output              = "../../../packages/database/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("todos")
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique @db.VarChar
  password       String           @db.VarChar
  name           String?          @db.VarChar
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  passkeys       Passkey[]

  @@map("users")
}

model Passkey {
  id             Int       @id @default(autoincrement())
  userId         Int
  credentialId   String    @unique @db.Text
  publicKey      Bytes
  counter        BigInt    @default(0)
  deviceType     String?   @db.VarChar
  backedUp       Boolean   @default(false)
  transports     String[]  @db.VarChar
  credentialName String?   @db.VarChar
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}


// Note: The keyv table is managed by @keyv/postgres package
// The @@ignore attribute tells Prisma not to manage this table
model Keyv {
  key   String @id @db.VarChar
  value String @db.Text

  @@map("keyv")
  @@ignore
}

// Job execution logs for real-time monitoring
model JobLog {
  id        Int      @id @default(autoincrement())
  jobId     String   @db.VarChar
  jobName   String?  @db.VarChar
  level     String   @db.VarChar
  message   String   @db.Text
  data      Json?    @db.Json
  timestamp DateTime @default(now()) @db.Timestamptz(6)

  @@index([jobId])
  @@index([timestamp])
  @@map("job_logs")
}


