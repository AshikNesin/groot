// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider            = "prisma-client"
  output              = "../../../packages/core/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("todos")
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique
  password       String
  name           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  passkeys       Passkey[]

  @@map("users")
}

model Passkey {
  id             Int       @id @default(autoincrement())
  userId         Int
  credentialId   String    @unique
  publicKey      Bytes
  counter        BigInt    @default(0)
  deviceType     String?
  backedUp       Boolean   @default(false)
  transports     String
  credentialName String?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}


// Note: The keyv table is managed by @keyv/sqlite package
// The @@ignore attribute tells Prisma not to manage this table
model Keyv {
  key   String @id
  value String

  @@map("keyv")
  @@ignore
}

// Job execution logs for real-time monitoring
// NOTE: pg-boss (the job queue) is Postgres-only and is intentionally NOT
// migrated to SQLite in this branch. As a result JobLog rows are never written
// (the job logger only runs inside pg-boss worker handlers). The table is kept
// in the schema so the generated client compiles and existing code that
// references `prisma.jobLog` stays valid, but jobs are effectively disabled.
model JobLog {
  id        Int      @id @default(autoincrement())
  jobId     String
  jobName   String?
  level     String
  message   String
  data      String?
  timestamp DateTime @default(now())

  @@index([jobId])
  @@index([timestamp])
  @@map("job_logs")
}


