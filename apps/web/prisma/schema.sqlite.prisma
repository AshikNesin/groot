// SQLite schema. Selected when DATABASE_ENGINE=sqlite (default).
// The model definitions are identical to schema.postgres.prisma; only the
// datasource provider differs. Keep the two files in sync — a parity test
// (tests/server/prisma/schema-parity.test.ts) asserts the models match.

generator client {
  provider            = "prisma-client"
  output              = "../../../packages/core/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("todos")
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  passkeys  Passkey[]

  @@map("users")
}

model Passkey {
  id             Int       @id @default(autoincrement())
  userId         Int
  credentialId   String    @unique
  publicKey      Bytes
  counter        BigInt    @default(0)
  deviceType     String?
  backedUp       Boolean   @default(false)
  transports     Json
  credentialName String?
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

// The keyv table is managed by @keyv/postgres / @keyv/sqlite at runtime, so
// Prisma must not create or migrate it. @@ignore keeps it out of migrations.
model Keyv {
  key   String @id
  value String

  @@map("keyv")
  @@ignore
}

// Job execution logs for real-time monitoring.
// NOTE: pg-boss (the job queue) is Postgres-only. When DATABASE_ENGINE=sqlite
// the job queue is disabled, so JobLog rows are never written; the table is
// kept in the schema so the generated client compiles and existing code that
// references `prisma.jobLog` stays valid on both engines.
model JobLog {
  id        Int      @id @default(autoincrement())
  jobId     String
  jobName   String?
  level     String
  message   String
  data      Json?
  timestamp DateTime @default(now())

  @@index([jobId])
  @@index([timestamp])
  @@map("job_logs")
}

// Honker job-queue tables. honker (@russellthehippo/honker-node, the SQLite
// queue) creates these at runtime via CREATE TABLE ... IF NOT EXISTS. They are
// mirrored here so Prisma's migration history stays in sync with the runtime
// schema — otherwise `prisma migrate dev` reports drift against tables it never
// created and tries to drop them. @@ignore keeps Prisma from generating DDL for
// these models; the canonical table/index definitions live in migration
// 20260316000000_honker_tables. The 3 partial (WHERE-predicate) indexes honker
// uses on _honker_live can't be expressed in Prisma syntax, so they exist only
// in the migration SQL (the @@index directives here omit them on purpose).
// honker is SQLite-only, so these models have no postgres counterpart.
model HonkerLive {
  id             Int      @id @default(autoincrement())
  queue          String
  payload        String
  state          String   @default("pending")
  priority       Int      @default(0)
  runAt          Int      @default(dbgenerated("unixepoch()")) @map("run_at")
  workerId       String?  @map("worker_id")
  claimExpiresAt Int?     @map("claim_expires_at")
  attempts       Int      @default(0)
  maxAttempts    Int      @default(3) @map("max_attempts")
  createdAt      Int      @default(dbgenerated("unixepoch()")) @map("created_at")
  expiresAt      Int?     @map("expires_at")

  @@map("_honker_live")
  @@ignore
}

model HonkerDead {
  id          Int     @id
  queue       String
  payload     String
  priority    Int     @default(0)
  runAt       Int     @default(0) @map("run_at")
  attempts    Int     @default(0)
  maxAttempts Int     @default(0) @map("max_attempts")
  lastError   String? @map("last_error")
  createdAt   Int     @default(dbgenerated("unixepoch()")) @map("created_at")
  diedAt      Int     @default(dbgenerated("unixepoch()")) @map("died_at")

  @@map("_honker_dead")
  @@ignore
}

model HonkerNotification {
  id        Int    @id @default(autoincrement())
  channel   String
  payload   String
  createdAt Int    @default(dbgenerated("unixepoch()")) @map("created_at")

  @@index([channel, id], map: "_honker_notifications_recent")
  @@map("_honker_notifications")
  @@ignore
}

model HonkerLock {
  name      String @id
  owner     String
  expiresAt Int    @map("expires_at")

  @@map("_honker_locks")
  @@ignore
}

model HonkerRateLimit {
  name        String
  windowStart Int @map("window_start")
  count       Int @default(0)

  @@id([name, windowStart])
  @@map("_honker_rate_limits")
  @@ignore
}

model HonkerSchedulerTask {
  name        String  @id
  queue       String
  cronExpr    String  @map("cron_expr")
  payload     String
  priority    Int     @default(0)
  expiresS    Int?    @map("expires_s")
  nextFireAt  Int     @map("next_fire_at")
  enabled     Int     @default(1)
  maxAttempts Int     @default(3) @map("max_attempts")

  @@map("_honker_scheduler_tasks")
  @@ignore
}

model HonkerResult {
  jobId     Int     @id @map("job_id")
  value     String?
  createdAt Int     @default(dbgenerated("unixepoch()")) @map("created_at")
  expiresAt Int?    @map("expires_at")

  @@map("_honker_results")
  @@ignore
}

model HonkerStream {
  offset    Int    @id @default(autoincrement())
  topic     String
  key       String?
  payload   String
  createdAt Int    @default(dbgenerated("unixepoch()")) @map("created_at")

  @@index([topic, offset], map: "_honker_stream_topic")
  @@map("_honker_stream")
  @@ignore
}

model HonkerStreamConsumer {
  name   String
  topic  String
  offset Int    @default(0)

  @@id([name, topic])
  @@map("_honker_stream_consumers")
  @@ignore
}
