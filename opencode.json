{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "zai",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "headers": {
          "Authorization": "Bearer {env:ZAI_API_KEY}"
        }
      },
      "models": {
        "glm-5": {
          "name": "GLM-5"
        },
        "glm-4.7": {
          "name": "GLM-4.7"
        }
      }
    }
  }
}
